{
  "expo": {
    "name": "LENTERA",
    "slug": "lentera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "lentera",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-icon.png",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow LENTERA to use speech recognition for live transcription.",
        "NSMicrophoneUsageDescription": "Allow LENTERA to use the microphone for classroom speech recognition.",
        "NSPhotoLibraryUsageDescription": "Allow LENTERA to access your photo library to set your profile picture.",
        "NSCameraUsageDescription": "Allow LENTERA to take a photo for your profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3a8a",
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.lentera.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1e3a8a",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-sqlite",
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "adc91b21-4289-4225-9d3b-8553185a063b"
      }
    },
    "owner": "draapy"
  }
}
